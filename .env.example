# Gemini API Configuration (Server-side only)
GEMINI_API_KEY=your_gemini_api_key_here

# PayPal Configuration (Client-side)
VITE_PAYPAL_CLIENT_ID=dd

# JWT Authentication (Server-side only)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:5173

# Client Configuration (Vite)
# For local development
VITE_API_URL=http://localhost:3001

# For Vercel deployment (will be set automatically)
# VITE_API_URL=https://your-app.vercel.app

# JewelryFit AI - Environment Variables
# Copy this file to .env.local and fill in your values

# Gemini API Key (Required)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# API Base URL (default: current domain)
VITE_API_URL=

# Cloud Run Backend URL (Optional - for full AI pipeline)
# Deploy jewelry_tryon_pipeline.py to Cloud Run and add URL here
# See VERCEL_DEPLOYMENT.md for instructions
VITE_BACKEND_API_URL=

# Example with Cloud Run:
# VITE_BACKEND_API_URL=https://jewelryfit-backend-xxxxx.run.app

# Vertex AI Project ID (Optional - if using Cloud Run)
VITE_VERTEX_PROJECT_ID=
